# Example environment configuration for the DB Tool dev databases.
# Copy this file to `.env` and adjust as needed. The real `.env` is
# gitignored (see .gitignore) — never commit real credentials.

# --- PostgreSQL (Docker) ---
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=dbtool_dev
PG_USER=dbtool
PG_PASSWORD=dbtool

# --- MySQL (Docker) ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=dbtool_dev
MYSQL_USER=dbtool
MYSQL_PASSWORD=dbtool
# Admin (root) credentials for MySQL, if needed:
MYSQL_ROOT_PASSWORD=rootpw

# --- SQLite (file-based, no container) ---
# Path where the app creates/opens the SQLite database file.
SQLITE_PATH=./db/sqlite/dbtool.sqlite
